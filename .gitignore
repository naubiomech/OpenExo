# =============================================================================
# Python GUI - per-user runtime data (NOT source)
# These files are written by the GUI at runtime and are user/machine-specific.
# Keeping them out of git avoids merge noise on every trial run.
# =============================================================================
Python_GUI/Saved_Data/saved_device.txt
Python_GUI/Saved_Data/gui_settings.txt
Python_GUI/Saved_Data/trial_*.csv
Python_GUI/Saved_Data/*.log

# =============================================================================
# iOS / Xcode user-specific state
# (project.pbxproj IS still tracked - only user-state is ignored)
# =============================================================================
**/xcuserdata/
*.xcuserstate
*.xcuserdatad
*.moved-aside
DerivedData/
build/

